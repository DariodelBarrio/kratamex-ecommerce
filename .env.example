# =================================================================
# KRATAMEX - Variables raiz para Docker Compose
# SOLO DESARROLLO LOCAL. NO USAR EN PRODUCCION.
# =================================================================

# PostgreSQL local de desarrollo
POSTGRES_DB=kratamex
POSTGRES_USER=kratamex
POSTGRES_PASSWORD=kratamex_dev

# Base de datos separada para el SOC (desarrollo local)
SOC_DB_NAME=kratamex_soc
SOC_ADMIN_USER=soc_admin_local
SOC_ADMIN_PASS=CAMBIAR_SOC_ADMIN_PASS_LOCAL

# Base de datos separada para clientes (desarrollo local)
CLIENT_DB_NAME=kratamex_clientes

# Email de desarrollo
EMAIL_FROM=dev@example.local
EMAIL_PASS=CAMBIAR_EMAIL_PASS_LOCAL

# VirusTotal opcional en local
VIRUSTOTAL_API_KEY=
