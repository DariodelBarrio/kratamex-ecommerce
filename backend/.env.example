# Credenciales locales de desarrollo
ADMIN_USER=admin_local
ADMIN_PASS=CAMBIAR_ADMIN_PASS_LOCAL
USER_STANDARD=user_local
USER_PASS=CAMBIAR_USER_PASS_LOCAL

# Credenciales independientes del SOC
SOC_ADMIN_USER=soc_admin_local
SOC_ADMIN_PASS=CAMBIAR_SOC_ADMIN_PASS_LOCAL

# PostgreSQL principal de desarrollo
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kratamex
DB_USER=kratamex
DB_PASSWORD=kratamex_dev

# Base de datos dedicada a clientes
CLIENT_DB_HOST=postgres
CLIENT_DB_PORT=5432
CLIENT_DB_NAME=kratamex_clientes
CLIENT_DB_USER=kratamex
CLIENT_DB_PASSWORD=kratamex_dev

# Base de datos dedicada al SOC
SOC_DB_HOST=postgres
SOC_DB_PORT=5432
SOC_DB_NAME=kratamex_soc
SOC_DB_USER=kratamex
SOC_DB_PASSWORD=kratamex_dev

# CORS local
CORS_ORIGIN=https://localhost

# Stripe test/local
STRIPE_SECRET_KEY=sk_test_CAMBIAR_EN_LOCAL
STRIPE_WEBHOOK_SECRET=whsec_CAMBIAR_EN_LOCAL

# VirusTotal opcional
VIRUSTOTAL_API_KEY=

# Email de desarrollo
